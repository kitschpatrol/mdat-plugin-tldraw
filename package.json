{
	"name": "mdat-plugin-tldraw",
	"version": "2.0.0",
	"description": "Mdat plugin to embed tldraw diagrams in Markdown files.",
	"keywords": [
		"markdown",
		"mdat-plugin",
		"mdat",
		"npm-package",
		"tldraw"
	],
	"homepage": "https://github.com/kitschpatrol/mdat-plugin-tldraw",
	"bugs": "https://github.com/kitschpatrol/mdat-plugin-tldraw/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/mdat-plugin-tldraw.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"files": [
		"dist/*"
	],
	"scripts": {
		"build": "tsdown --no-fixed-extension --tsconfig tsconfig.build.json",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"release": "bumpp --commit 'Release: %s' && pnpm run build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') && pnpm publish",
		"test": "vitest run"
	},
	"dependencies": {
		"@kitschpatrol/tldraw-cli": "^5.0.14",
		"path-type": "^6.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^7.0.1",
		"@types/node": "~20.19.37",
		"bumpp": "^11.0.1",
		"mdat": "^2.1.0",
		"remark-mdat": "^2.1.0",
		"tsdown": "^0.21.7",
		"typescript": "~5.9.3",
		"vitest": "^4.1.2"
	},
	"peerDependencies": {
		"mdat": "^2.0.0",
		"remark-mdat": "^2.0.0"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=20.19.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=22.21.0"
		}
	}
}
